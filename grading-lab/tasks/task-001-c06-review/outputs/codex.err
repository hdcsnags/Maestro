201-// Produce a stable fingerprint of all non-terminal build tasks.
202-// Two identical fingerprints across consecutive waves means the frontier is
203-// frozen (same tasks, same statuses, same lane owners, same retry counts) —
204-// a true cycle or deadlock, not forward progress being masked by reroutes.
205:function fingerprintNonterminalTasks(tasks: BuildTask[]): string {
206-  return tasks
207-    .filter(t => t.status !== 'completed' && t.status !== 'failed' && t.status !== 'skipped')
