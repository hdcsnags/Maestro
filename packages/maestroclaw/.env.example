# MaestroClaw local config
# Copy to .env and fill in values

# Supabase project URL (same as your Maestro frontend)
SUPABASE_URL=

# Supabase anon key (same as your Maestro frontend)
SUPABASE_ANON_KEY=

# Executor token (shown once during registration — save it!)
# This is sufficient for polling and job execution — no account password is stored on disk.
EXECUTOR_TOKEN=

# Poll interval in ms (default: 5000)
POLL_INTERVAL_MS=5000

# Keep workspace directories for succeeded jobs (default: true)
KEEP_SUCCEEDED_WORKSPACES=true

# Workspace directory for ephemeral clones (default: ~/.maestroclaw/workspaces)
WORKSPACE_DIR=

# ─── Claude Code adapter ───────────────────────────────────────────────────────
# Model used for all claude_code jobs. Defaults to Sonnet — change to a cheaper
# or more capable model as needed. Opus burns quota ~7x faster than Sonnet.
CLAW_CLAUDE_MODEL=claude-sonnet-4-6

# Optional fallback model. When set, a rate-limited primary run automatically
# retries with this model instead of failing the job outright.
# Example: CLAW_CLAUDE_FALLBACK_MODEL=claude-sonnet-4-5
CLAW_CLAUDE_FALLBACK_MODEL=claude-sonnet-4-5
